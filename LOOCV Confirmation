# Map unique output strings to integers for scikit-learn
# This ensures consistency with how unique_outputs_list was created
output_to_int = {output: i for i, output in enumerate(unique_outputs_list)}
y_encoded = np.array([output_to_int[label] for label in y])

# Re-calculate correlation ratios for all features to get original rankings
