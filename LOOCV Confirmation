def evaluate_feature_pair_with_loocv(feature_indices):
    """
    Evaluates the accuracy of a K-Nearest Neighbors (k=1) classifier
    using Leave-One-Out Cross-Validation for a given pair of features.

    Args:
        feature_indices (tuple): A tuple containing the original indices of the two features to use.

    Returns:
        float: The LOOCV accuracy for the given feature pair.
    """
    # Select only the chosen features from the dataset
    X_selected = X[:, feature_indices]

    loo = LeaveOneOut()
    knn = KNeighborsClassifier(n_neighbors=1) # Nearest Neighbor (k=1)
    
    y_true = []
    y_pred = []

    for train_index, test_index in loo.split(X_selected):
        X_train, X_test = X_selected[train_index], X_selected[test_index]
        y_train, y_test = y_encoded[train_index], y_encoded[test_index]

        knn.fit(X_train, y_train)
        y_pred.extend(knn.predict(X_test))
        y_true.extend(y_test)

    accuracy = accuracy_score(y_true, y_pred)
    return accuracy

print("\n--- Evaluating All Possible Feature Pairs with LOOCV (k=1 Nearest Neighbor) ---")

all_feature_indices = list(range(9)) # Indices 0 through 8 for the 9 features
all_pairs = list(itertools.combinations(all_feature_indices, 2))

pair_accuracies = []

for pair_indices in all_pairs:
    accuracy = evaluate_feature_pair_with_loocv(pair_indices)
    feature_name1 = headers[pair_indices[0]]
    feature_name2 = headers[pair_indices[1]]
    pair_accuracies.append((accuracy, pair_indices, (feature_name1, feature_name2)))

# Sort pairs by accuracy in descending order
pair_accuracies.sort(key=lambda x: x[0], reverse=True)

print("\nRanked Feature Pairs by LOOCV Accuracy (Higher is Better):")
for rank, (accuracy, indices, names) in enumerate(pair_accuracies):
    print(f"Rank {rank+1}: {names[0]} (Index {indices[0]}) and {names[1]} (Index {indices[1]}) - Accuracy: {accuracy:.4f}")

