#Do note that this may not be the actual results as this is only a prediction

try:
  #Reading CSV file
  with open("glass1.csv","r") as f:
    raw_data = f.read().split("\n")[1:]
  #Cleaning up row to get floats and last string
  def clean_row(row):
    temp_row = []
    temp_string = ""
    row += ","
    for i in row:
      if i != ",":
        temp_string += i
      else:
        temp_row.append(temp_string)
        temp_string = ""
    clean_row = []
    for i in range(len(temp_row)-1):
      clean_row.append(float(temp_row[i]))
    clean_row.append(temp_row[-1])
    return clean_row
  #Cleaning up all training data
  training_data = []
  for i in raw_data:
    training_data.append(clean_row(i))
  training_data.pop()

  temp_list = []
  column_list = []

  for i in range(10):
    for j in training_data:
      temp_list.append(j[i])
    column_list.append(temp_list)
    temp_list = []

  def grouper(column,output):
    group_list = []
    for i in range(len(training_data)):
      if column_list[9][i] == output:
        group_list.append(column_list[column][i])
    return group_list

  unique_outputs_set = set(column_list[9])
  unique_outputs_list = []
  for i in unique_outputs_set:
    unique_outputs_list.append(i)
  #['Building Windows_float processed', 'containers', 'tableware', 'headlamps', 'Vehicle_wondows_float_processed', 'Builidng Windows_non float processed']

  feature_groups = []
  feature_groups_single = []
  for j in range(9):
    for i in range(len(unique_outputs_list)):
      feature_groups_single += [grouper(j,unique_outputs_list[i])]
    feature_groups += [feature_groups_single]
    feature_groups_single = []
  #First index is feature, second is type of group

  def calculate_mean(feature_column):
    group_to_flatten = feature_groups[feature_column]
    flatten_list = []
    for i in range(len(group_to_flatten)):
      flatten_list += group_to_flatten[i]
    sum = 0
    for i in flatten_list:
      sum += i
    mean = sum / len(flatten_list)
    return mean

  def calculate_correlation_ratio(feature_column):
    denominator = 0
    numerator = 0

    overall_group_mean = calculate_mean(feature_column)
    feature_group_data = feature_groups[feature_column]

    for i in range(len(unique_outputs_list)):
      instance_group_sum = 0
      instance_group_length = len(feature_group_data[i])

      for j in feature_group_data[i]:
        instance_group_sum += j
      instance_group_mean = instance_group_sum / instance_group_length
      numerator += instance_group_length * (instance_group_mean - overall_group_mean) ** 2

    all_group_data = []
    for i in range(len(feature_group_data)):
      all_group_data += feature_group_data[i]

    for k in all_group_data:
      denominator += (k - overall_group_mean)**2

    if denominator == 0:
      return 0.0

    corelation_ratio = numerator / denominator
    return corelation_ratio  

  correlation = []
  for i in range(9):
    correlation.append(calculate_correlation_ratio(i))

  best_feature = correlation.index(max(correlation))
  correlation.pop(best_feature)
  second_best_feature = correlation.index(max(correlation)) + 1 #Since i popped the list, all indices are artifically lower by 1 than they should be
  
  headers = ["Refractive Index", "Sodium",	"Magnesium",	"Aluminium",	"Silicon",	"Potassium",	"Calcium",	"Barium",	"Iron"]

  print(f"1st most important feature: Feature {best_feature+1}, {headers[best_feature]}")
  print(f"2nd most important feature: Feature {second_best_feature+1}, {headers[second_best_feature]}")
except FileNotFoundError:
  print("Upload the file named 'glass1.csv' before running the program!") 

