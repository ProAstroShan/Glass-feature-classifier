# Importing dependent modules
import pandas as pd
import collections
import itertools
import os
import matplotlib.pyplot as plt
import numpy as np

# Formatting table data into an ordered dictionary
formatted_data: dict[str, list[float]] = collections.defaultdict(list)
try:
    data = pd.read_csv("glass1.csv")
except FileNotFoundError as e:
    print(e)
else:
    # Asks for consent before running program
    if input(
        "This program will create a folder while creating 28 images and saving\nthem into the folder. Type Y or Yes to agree: ").upper() in ["Y", "YES"]:
        # Does not include glass, will be added later
        feature_headers: list[str] = [
            "Refractive Index",
            "Sodium",
            "Magnesium",
            "Aluminium",
            "Silicon",
            "Potassium",
            "Barium",
            "Iron",
        ]
        for headers in feature_headers:
            for data_points in data[headers]:
                formatted_data[headers].append(data_points)
        for glass_type in data["Glass"]:
            formatted_data["Glass"].append(glass_type)

        # Creaing a list of tuples, containing combinations of pairs
        feature_pairs: list[tuple[str, str]] = list(
            itertools.combinations(feature_headers, 2))

        # Using elements of the above as keys, the value will be 2 lists of 2 features respectively
        feature_pairs_dict: dict[tuple[str, str], list[list[float]]] = {}
        for pairs in feature_pairs:
            feature_pairs_dict[pairs] = [
                formatted_data[pairs[0]],
                formatted_data[pairs[1]],
            ]

        # Creates the x_axis and y_axis for each feature pair graph
        def generate_axes(graph_num: int,) -> tuple[tuple[str, str], list[float], list[float]]:
            pair: tuple[str, str] = feature_pairs[graph_num]
            x_axis: list[float] = feature_pairs_dict[pair][0]
            y_axis: list[float] = feature_pairs_dict[pair][1]
            return pair, x_axis, y_axis

        # Generates all 28 feature pair graphs one by one
        for graph_num in range(len(feature_pairs)):
            pair, x_axis, y_axis = generate_axes(graph_num)

            # Allows us to categorise each glass type as an integer to compare colours
            glass_labels_numeric: np.ndarray = pd.factorize(data["Glass"])[0]
            
            # pd.factorize converts glass type names into numerical labels and extracts
            # the original glass type names to be used for plot colouring and legend 
            # labelling respectively
            unique_glass_types = pd.factorize(data["Glass"])[1]
            plt.figure(figsize=(17, 11))
            
            # When the glass codes is passed to c (colour), each code will get its
            # own colour.
            scatter = plt.scatter(x_axis, y_axis, c=glass_labels_numeric, cmap="viridis", alpha=0.7)

            # Filters out the extreme outliers in the top and bottom percentile
            # from skewing the graph, allowing for better comparison of clusters
            x_lower_bound = np.percentile(x_axis, 1)
            x_upper_bound = np.percentile(x_axis, 99)
            y_lower_bound = np.percentile(y_axis, 1)
            y_upper_bound = np.percentile(y_axis, 99)
            plt.xlim(x_lower_bound, x_upper_bound)
            plt.ylim(y_lower_bound, y_upper_bound)

            # Initialising labels and title
            plt.xlabel(pair[0], size=17)
            plt.ylabel(pair[1], size=17)
            plt.title(f"Scatter Plot of {pair[0]} vs. {pair[1]} (Colored by Glass Type)",size=20,)

            plt.xticks(fontsize=15)
            plt.yticks(fontsize=15)

            # The unique names of glass is used as the labels for each colour a glass type is
            # assigned in the colour bar
            cbar = plt.colorbar(scatter, ticks=range(len(unique_glass_types)))
            cbar.set_ticklabels(list(unique_glass_types))
            cbar.set_label("Glass Type", size=17)
            cbar.ax.tick_params(labelsize=17)

            plt.grid(True, linestyle="--", alpha=0.7)
            plt.tight_layout()

            # Creates a folder, where images created will be saved into
            folder_path: str = "Feature_Pair_Images"
            image_path: str = f"{pair[0]} vs. {pair[1]}.png"
            full_path: str = os.path.join(folder_path, image_path)
            os.makedirs(folder_path, exist_ok=True)
            plt.savefig(fname=full_path, format="png")
            plt.close()
        print("\nProgram ran successfully. Check the folder 'Feature_Pair Images' to see graphs! ")
    else:
        print("\nConsent was not given. Give consent to run the program.")
